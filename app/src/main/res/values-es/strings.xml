    <string name="perm_usage_stats_title">Datos de uso de apps</string>
    <string name="perm_usage_stats_desc">AppLock necesita detectar qué aplicación está abierta para mostrar la pantalla de bloqueo en el momento adecuado. Para ello se requiere acceso a los datos de uso de apps. Sin este permiso, no se puede bloquear ninguna app.</string>

    <string name="perm_overlay_title">Mostrar sobre otras apps</string>
    <string name="perm_overlay_desc">La pantalla de bloqueo se muestra encima de la app bloqueada. Para ello se necesita el permiso \'Mostrar sobre otras apps\'. Sin este permiso, no puede aparecer ninguna pantalla de bloqueo.</string>

    <string name="perm_exact_alarm_title">Alarmas exactas</string>
    <string name="perm_exact_alarm_desc">Las alarmas exactas se usan para un reinicio automático fiable del servicio de bloqueo. Sin este permiso, el servicio puede tardar un poco en iniciarse tras un reinicio, pero la función de bloqueo se mantiene.</string>

    <string name="perm_camera_title">Cámara</string>
    <string name="perm_camera_desc">Si se introduce una contraseña incorrecta varias veces, AppLock puede tomar una foto del intruso de forma opcional. Esta función también puede activarse o desactivarse más adelante en los ajustes.</string>

