<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical">

    <include
        layout="@layout/layout_toolbar"
        android:visibility="gone"/>

    <RelativeLayout
        android:id="@+id/top_layout"
        android:layout_width="match_parent"
        android:layout_height="226dp"
        android:background="#2DAC7C">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:adjustViewBounds="true"
            android:padding="10dp"
            android:src="@drawable/ic_back_2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_toRightOf="@+id/btn_back"
            android:gravity="center"
            android:text="App-Sperre"
            android:textColor="@color/white"
            android:textSize="14sp"/>

        <ImageView
            android:id="@+id/lock_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_lock"/>

        <TextView
            android:id="@+id/lock_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/lock_icon"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Willkommen bei App-Sperre"
            android:textColor="@color/white"
            android:textSize="14sp"/>
    </RelativeLayout>

    <!-- Sperrmethode auswählen -->
    <LinearLayout
        android:id="@+id/method_selection_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/btn_select_pin"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/lock_method_pin"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:background="@drawable/bg_btn_blue"/>

        <TextView
            android:id="@+id/btn_select_pattern"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginLeft="12dp"
            android:gravity="center"
            android:text="@string/lock_method_pattern"
            android:textColor="@color/font_deep_gray"
            android:textSize="14sp"
            android:background="@drawable/bg_btn_method_unselected"/>
    </LinearLayout>

    <!-- PIN/Passwort-Abschnitt (Standard: sichtbar) -->
    <LinearLayout
        android:id="@+id/pin_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="8dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/pin_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/pin_enter_hint"
            android:textColor="@color/font_deep_gray"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_pin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:inputType="textPassword"
            android:hint="@string/pin_enter_hint"
            android:contentDescription="@string/pin_enter_hint"
            android:gravity="center"
            android:background="@drawable/bg_frame_search"
            android:padding="8dp"/>

        <EditText
            android:id="@+id/et_pin_confirm"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:inputType="textPassword"
            android:hint="@string/pin_confirm_hint"
            android:contentDescription="@string/pin_confirm_hint"
            android:gravity="center"
            android:background="@drawable/bg_frame_search"
            android:padding="8dp"
            android:layout_marginTop="10dp"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/btn_pin_next"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_btn_blue"
            android:text="@string/pin_confirm"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <!-- Muster-Abschnitt (Standard: nicht sichtbar) -->
    <com.lzx.lock.widget.LockPatternView
        android:id="@+id/lock_pattern_view"
        android:layout_width="290dp"
        android:layout_height="290dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/btn_reset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:gravity="center"
        android:text="Zurücksetzen"
        android:layout_marginBottom="10dp"
        android:textColor="@color/tr_black50"
        android:textSize="14sp"
        android:visibility="gone"/>

</LinearLayout>