<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools"
          package="com.lzx.lock">

    <!--Benötigte Berechtigungen für App-Sperre-->
    <uses-permission android:name="android.permission.GET_TASKS"/>
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.CAMERA"/>


    <application
        android:name=".LockApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:manageSpaceActivity=".module.splash.SplashActivity"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".module.splash.SplashActivity"
            android:exported="true"
            android:label="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".module.splash.PermissionSetupActivity"
            android:exported="false"
            android:label="Berechtigungen einrichten"/>

        <activity
            android:name=".module.pwd.CreatePwdActivity"
            android:exported="false"
            android:label="Passwort erstellen"/>
        <activity
            android:name=".module.lock.SelfUnlockActivity"
            android:exported="false"
            android:label="Entsperren"/>
        <activity
            android:name=".module.lock.UnlockActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:label=""
            android:launchMode="singleTask"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/unlock_activity_style"/>
        <activity
            android:name=".module.setting.LockSettingActivity"
            android:exported="false"
            android:label="Einstellungen"/>
        <activity
            android:name=".module.lock.LockCreateActivity"
            android:exported="false"
            android:label="Mustersperre erstellen"/>
        <activity
            android:name=".module.main.MainActivity"
            android:exported="false"/>

        <service
            android:name=".service.LoadAppListService"
            android:exported="false"/>
        <service
            android:name=".service.LockService"
            android:exported="false"/>

        <receiver
            android:name=".receiver.ServiceRestartReceiver"
            android:exported="false"/>

        <receiver
            android:name=".receiver.BootBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </receiver>

        <!--
            Import/Export-Receiver: geschützt durch android.permission.DUMP.
            Nur der ADB-Shell-Nutzer (uid 2000) und System-Apps besitzen diese Berechtigung.
            Reguläre Nutzer-Apps können diesen Receiver nicht aufrufen.

            Export-Befehl (adb):
              adb shell am broadcast -a com.lzx.lock.EXPORT_SETTINGS \
                  - -es path /sdcard/Android/data/com.lzx.lock/files/applock_settings.json

            Import-Befehl (adb):
              adb shell am broadcast -a com.lzx.lock.IMPORT_SETTINGS \
                  - -es path /sdcard/Android/data/com.lzx.lock/files/applock_settings.json
        -->
        <receiver
            android:name=".receiver.ImportExportReceiver"
            android:permission="android.permission.DUMP"
            android:exported="true">
            <intent-filter>
                <action android:name="com.lzx.lock.EXPORT_SETTINGS"/>
                <action android:name="com.lzx.lock.IMPORT_SETTINGS"/>
            </intent-filter>
        </receiver>
    </application>

</manifest>